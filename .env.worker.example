# Required by the worker API.
WORKER_API_TOKEN=replace-with-strong-shared-worker-token

# Diana app base URL. In production this should be the deployed Diana origin.
DIANA_WORKER_BASE_URL=https://your-diana-app.example

# Required by the Diana sidecar executor.
OPENJARVIS_BASE_URL=http://openjarvis:8000
OPENJARVIS_MODEL=llama3.2:3b

# Optional worker controls.
DIANA_WORKER_ID=voice-worker-1
DIANA_WORKER_QUEUE=student-ai-candidate
DIANA_WORKER_IMAGE_SHA=replace-with-worker-image-sha
