{
  "name": "diana",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --turbo",
    "desktop": "node scripts/electron-dev.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:open": "electron electron/main.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "tone-audit": "npx tsx scripts/tone-audit.ts",
    "command-center:handoff": "npx tsx scripts/create-command-center-handoff.ts",
    "command-center:paperclip-issue": "npx tsx scripts/create-paperclip-gstack-issue.ts",
    "command-center:paperclip-submit": "npx tsx scripts/submit-paperclip-gstack-issue.ts",
    "command-center:openjarvis-test": "npx tsx scripts/test-openjarvis-sidecar.ts --provider=openjarvis --base-url=http://127.0.0.1:8000 --model=llama3.2:3b",
    "command-center:local-ai-test": "npx tsx scripts/test-openjarvis-sidecar.ts",
    "command-center:audit": "npx tsx scripts/command-center-audit.ts",
    "worker:build": "node scripts/build-worker.mjs",
    "worker:runtime-smoke": "npm run worker:build && node scripts/smoke-worker-runtime.mjs",
    "worker:test": "vitest run lib/worker-tier/production-worker-tier.test.ts lib/worker-tier/worker-api-auth.test.ts lib/worker-tier/worker-queue.test.ts lib/worker-tier/worker-runner.test.ts lib/worker-tier/worker-metrics.test.ts lib/supabase/middleware.test.ts app/api/workers/claim/route.test.ts app/api/workers/complete/route.test.ts app/api/workers/metrics/route.test.ts app/api/workers/metrics/prometheus/route.test.ts app/api/diana/voice-candidate/route.test.ts app/api/diana/voice-candidate/status/route.test.ts lib/integrations/diana-voice-sidecar.test.ts lib/integrations/openjarvis-sidecar.test.ts",
    "worker:e2e-smoke": "npm run worker:build && npx tsx scripts/run-worker-e2e-smoke.ts",
    "worker:diana": "npx tsx scripts/run-diana-worker.ts",
    "worker:diana:compiled": "node dist/worker/run-diana-worker.cjs",
    "worker:tenant-canary": "npx tsx scripts/run-worker-tenant-canary.ts",
    "worker:deployed-canary": "npx tsx scripts/run-worker-deployed-canary.ts",
    "worker:load-smoke": "npx tsx scripts/run-worker-load-smoke.ts",
    "worker:diana-status-smoke": "npm run worker:build && npx tsx scripts/run-diana-status-polling-smoke.ts",
    "worker:production-preflight": "npx tsx scripts/worker-production-preflight.ts",
    "worker:deployment-check": "npx tsx scripts/validate-worker-deployment.ts",
    "worker:gate-evidence-check": "npx tsx scripts/verify-worker-gate-evidence.ts",
    "worker:image-evidence-check": "npx tsx scripts/verify-worker-image-evidence.ts",
    "gstack:browse": "npx tsx scripts/run-gstack-browse.ts",
    "launch-audit": "npx tsx scripts/launch-audit.ts",
    "competitive-score": "npx tsx scripts/competitive-score.ts",
    "teen-ux-score": "npx tsx scripts/teen-ux-score.ts",
    "qa:auth-preflight": "npx tsx scripts/qa-auth-preflight.ts",
    "qa:visual-gate": "node scripts/qa-visual-gate.mjs",
    "qa:screenshot-worthy": "node scripts/screenshot-worthy-qa.mjs",
    "qa:responsive": "playwright test tests/responsive-qa.spec.ts --reporter=line --workers=1",
    "test:e2e": "playwright test tests/e2e-flows.spec.ts --reporter=line --workers=1"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "@fontsource/opendyslexic": "^5.2.5",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "date-fns": "^4.1.0",
    "heic2any": "^0.0.4",
    "idb-keyval": "^6.2.4",
    "lucide-react": "^0.460.0",
    "next": "15.5.18",
    "node-ical": "^0.26.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "three": "^0.184.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "electron": "^42.3.3",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.0",
    "sharp": "^0.35.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4",
    "yaml": "^2.9.0"
  }
}
