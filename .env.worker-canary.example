# Required by canary/load-smoke seeding and production preflight schema checks.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Required by backend worker API checks.
WORKER_API_TOKEN=replace-with-strong-shared-worker-token
DIANA_WORKER_BASE_URL=https://your-diana-app.example

# Optional: require deployed-worker canary to be completed by this worker image.
DIANA_WORKER_EXPECTED_IMAGE_SHA=replace-with-worker-image-sha
